{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenWatch",
  "version": "0.2.4",
  "identifier": "com.tokenwatch.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TokenWatch",
        "width": 1280,
        "height": 832,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "skipTaskbar": false
      },
      {
        "label": "popover",
        "title": "TokenWatch",
        "width": 360,
        "height": 480,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Monitor Claude / Codex token usage",
    "longDescription": "TokenWatch is a macOS menu-bar app that monitors Claude and Codex token usage per project and workspace, with limit alerts."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.tokenwatch.gulloa.click/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNzk2MDI4NDkyRTVGRDcKUldUWFh5NUpLR0I1NGd2TEFlQzZITWEvUmZOdG9VUlVoYm0xUkVjNXN0d2FxbFA1dGZzam1ZcUEK"
    }
  }
}
