#!/usr/bin/env bash
# Clean up build artifacts and temporary files before archiving a Conductor workspace.
#
# Removes the heavy, regenerable directories (node_modules, Rust target, build output)
# so the workspace can be archived without dragging gigabytes around.
#
# Usage: bin/dev-archive
set -u

# Anchor at the repo root, not packages/app — this is a pnpm monorepo and
# dependencies are hoisted to the root node_modules, outside packages/app.
APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WORKSPACE="$(git -C "$APP_DIR" rev-parse --show-toplevel 2>/dev/null || cd "$APP_DIR/../.." && pwd)"

# Paths relative to $WORKSPACE (repo root) that should be removed if present.
TARGETS=(
  node_modules
  packages/app/node_modules
  packages/app/dist
  packages/app/dist-ssr
  packages/app/src-tauri/target
  packages/app/src-tauri/gen/schemas
  packages/app/staging
  packages/app/latest.json
  packages/app/.env.release
  packages/infra/node_modules
  packages/infra/cdk.out
  cdk.out
)

human_size() {
  if [ -e "$1" ]; then
    du -sh "$1" 2>/dev/null | awk '{print $1}'
  else
    echo "-"
  fi
}

removed_any=0
for rel in "${TARGETS[@]}"; do
  path="$WORKSPACE/$rel"
  if [ -e "$path" ]; then
    size="$(human_size "$path")"
    rm -rf "$path"
    echo "✓ Removed $rel ($size)"
    removed_any=1
  fi
done

if [ "$removed_any" -eq 0 ]; then
  echo "Nothing to clean — workspace is already tidy."
fi

echo ""
echo "Archive cleanup complete!"
